<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260605000003-1" author="convention">
        <createTable tableName="avenant">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="numero_avenant" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="date_signature" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="type_avenant" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="objet" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="nouvelle_echeance" type="date"/>
            <column name="montant_additionnel" type="decimal(21,2)"/>
            <column name="modifications_clauses" type="${clobType}"/>
            <column name="statut" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="date_creation" type="${datetimeType}"/>
            <column name="convention_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260605000003-2" author="convention">
        <addForeignKeyConstraint
            baseColumnNames="convention_id"
            baseTableName="avenant"
            constraintName="fk_avenant_convention_id"
            referencedColumnNames="id"
            referencedTableName="convention"/>
    </changeSet>

</databaseChangeLog>

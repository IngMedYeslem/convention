<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260612000001-1" author="convention">
        <createTable tableName="unite_organisationnelle">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nom" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="varchar(30)">
                <constraints unique="true" nullable="true"/>
            </column>
            <column name="niveau" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="parent_id" type="bigint">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="unite_organisationnelle"
            baseColumnNames="parent_id"
            constraintName="fk_unite_parent"
            referencedTableName="unite_organisationnelle"
            referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
